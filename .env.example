# PyTo Code Configuration (Claude Code compatible)

# Aliyun Dashscope API (or Anthropic official)
# Get from https://dashscope.console.aliyun.com/
ANTHROPIC_AUTH_TOKEN=sk-sp-your-api-key-here
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# Model configuration (Claude Code style)
ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.5
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5

# Fallback (if Claude Code env vars not set)
PYTO_MODEL=claude-sonnet-4-20250514
